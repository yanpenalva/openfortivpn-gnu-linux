#!/usr/bin/env bash

set -euo pipefail

VPN_HOST="${VPN_HOST:-<YOUR_VPN_HOST>}"
VPN_PORT="${VPN_PORT:-443}"
OPENFORTIVPN_BIN="${OPENFORTIVPN_BIN:-openfortivpn}"
OPENFORTIVPN_TRUSTED_CERT="${OPENFORTIVPN_TRUSTED_CERT:-}"
OPENFORTIVPN_SAML_BROWSER="${OPENFORTIVPN_SAML_BROWSER:-}"

require_command() {
  local command="$1"

  if ! command -v "$command" >/dev/null 2>&1; then
    echo "Required command not found: $command"
    exit 1
  fi
}

require_command sudo
require_command "$OPENFORTIVPN_BIN"
if [[ -n "$OPENFORTIVPN_SAML_BROWSER" ]]; then
  require_command "$OPENFORTIVPN_SAML_BROWSER"
fi

version="$("$OPENFORTIVPN_BIN" --version | head -n 1)"

if ! "$OPENFORTIVPN_BIN" --help | grep -qi saml; then
  echo "$version does not support SAML login."
  echo "Install openfortivpn 1.24.1 or newer."
  exit 1
fi

echo "Client: $version"
echo "Gateway: ${VPN_HOST}:${VPN_PORT}"
echo "Authentication: SAML"
if [[ -n "$OPENFORTIVPN_TRUSTED_CERT" ]]; then
  echo "Certificate pinning: enabled"
fi
if [[ -n "$OPENFORTIVPN_SAML_BROWSER" ]]; then
  echo "SAML browser: $OPENFORTIVPN_SAML_BROWSER"
fi
echo

openfortivpn_args=("${VPN_HOST}:${VPN_PORT}" --saml-login)

if [[ -n "$OPENFORTIVPN_TRUSTED_CERT" ]]; then
  openfortivpn_args+=(--trusted-cert "$OPENFORTIVPN_TRUSTED_CERT")
fi

if [[ -n "$OPENFORTIVPN_SAML_BROWSER" ]]; then
  export BROWSER="$OPENFORTIVPN_SAML_BROWSER"
  sudo /usr/bin/env "BROWSER=$BROWSER" "PATH=$PATH" "$OPENFORTIVPN_BIN" "${openfortivpn_args[@]}"
else
  sudo "$OPENFORTIVPN_BIN" "${openfortivpn_args[@]}"
fi
